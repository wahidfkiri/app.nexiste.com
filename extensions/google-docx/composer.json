{
    "name": "nexus-extensions/google-docx",
    "description": "Extension Google Docs pour NexusCRM — Gestionnaire de documents complet avec OAuth2 par tenant",
    "type": "library",
    "license": "proprietary",
    "version": "1.0.0",
    "keywords": ["google-docs", "docx", "document", "crm", "extension", "oauth2"],
    "autoload": {
        "psr-4": {
            "NexusExtensions\\GoogleDocx\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NexusExtensions\\GoogleDocx\\GoogleDocxServiceProvider"
            ]
        },
        "nexus-extension": {
            "slug": "google-docx",
            "name": "Google Docs",
            "version": "1.0.0",
            "category": "productivity",
            "pricing_type": "free"
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "google/apiclient": "^2.15"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0"
    }
}
