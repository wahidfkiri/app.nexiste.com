{
    "name": "nexus-extensions/google-gmail",
    "description": "Extension Google Gmail pour NexusCRM - boite mail complete par tenant via OAuth2",
    "type": "library",
    "license": "proprietary",
    "version": "1.0.0",
    "keywords": ["google-gmail", "gmail", "email", "crm", "extension", "oauth2"],
    "autoload": {
        "psr-4": {
            "NexusExtensions\\GoogleGmail\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NexusExtensions\\GoogleGmail\\GoogleGmailServiceProvider"
            ]
        },
        "nexus-extension": {
            "slug": "google-gmail",
            "name": "Google Gmail",
            "version": "1.0.0",
            "category": "communication",
            "pricing_type": "free"
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "google/apiclient": "^2.15"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0"
    }
}
