{
    "name": "nexus-extensions/google-drive",
    "description": "Extension Google Drive pour NexusCRM — File manager complet avec OAuth2 par tenant",
    "type": "library",
    "license": "proprietary",
    "version": "1.0.0",
    "keywords": ["google-drive", "storage", "crm", "extension", "oauth2"],
    "autoload": {
        "psr-4": {
            "NexusExtensions\\GoogleDrive\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NexusExtensions\\GoogleDrive\\GoogleDriveServiceProvider"
            ]
        },
        "nexus-extension": {
            "slug": "google-drive",
            "name": "Google Drive",
            "version": "1.0.0",
            "category": "storage",
            "pricing_type": "free"
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "google/apiclient": "^2.15",
        "league/flysystem-google-drive": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0"
    }
}