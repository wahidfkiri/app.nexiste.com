{
    "name": "vendor/rbac",
    "description": "Module RBAC — Rôles et Permissions UI-driven pour CRM SaaS multi-tenant (par-dessus Spatie Permission)",
    "type": "library",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "Vendor\\Rbac\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vendor\\Rbac\\RbacServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "spatie/laravel-permission": "^6.0",
        "vendor/crm-core": "*",
        "vendor/user": "*"
    }
}